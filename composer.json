{
    "name": "joshbodnar/ip-logger",
    "description": "A PHP package for logging IP addresses",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "IpLogger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IpLogger\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "psr/http-message": "^1.0 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/phpcs --standard=PSR12 src/",
        "lint:fix": "vendor/bin/phpcbf --standard=PSR12 src/",
        "phpstan": "vendor/bin/phpstan analyse src",
        "phpstan:baseline": "vendor/bin/phpstan analyse src --generate-baseline"
    },
    "config": {
        "sort-packages": true
    }
}
